# Server
NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# Never skip DB in production
SKIP_DB=false

# MongoDB Atlas — replace <user>, <password>, <cluster>
# Example: mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/follstack?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/follstack?retryWrites=true&w=majority

# Auth — generate long random strings (openssl rand -hex 32)
JWT_SECRET=
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=
JWT_REFRESH_EXPIRE=30d

# CORS — your production web origin(s), comma-separated if needed
# Example: https://follstack.netlify.app
CORS_ORIGIN=https://YOUR_WEB_DOMAIN

# AI (optional)
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log

# Email (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@YOUR_DOMAIN

# Public URLs for OAuth redirects
WEB_APP_URL=https://YOUR_WEB_DOMAIN
API_PUBLIC_URL=https://YOUR_API_DOMAIN

# Encrypt integration tokens (openssl rand -hex 32)
INTEGRATION_TOKEN_ENCRYPTION_KEY=

# GitHub OAuth App
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Vercel OAuth
VERCEL_CLIENT_ID=
VERCEL_CLIENT_SECRET=
