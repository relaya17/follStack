# Local development
NODE_ENV=development
PORT=3001
HOST=localhost
SKIP_DB=true
MONGODB_URI=mongodb://localhost:27017/follstack

# Auth — change before any shared/staging deploy
JWT_SECRET=dev-only-change-me
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=dev-only-refresh-change-me
JWT_REFRESH_EXPIRE=30d

# Must match the Next.js origin
CORS_ORIGIN=http://localhost:3000

# Put your OpenAI key here for real AI Mentor answers
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

LOG_LEVEL=info
LOG_FILE=logs/app.log
