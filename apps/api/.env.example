# Server
NODE_ENV=development
PORT=3001
HOST=localhost

# Skip MongoDB when running locally without a database
SKIP_DB=true

# Database (used when SKIP_DB is not true)
MONGODB_URI=mongodb://localhost:27017/follstack

# Auth
JWT_SECRET=dev-only-change-me
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=dev-only-refresh-change-me
JWT_REFRESH_EXPIRE=30d

# CORS — Next.js web app
CORS_ORIGIN=http://localhost:3000

# Optional integrations
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log
