{
  "name": "follstack",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm --parallel --filter @follstack/api --filter @follstack/web dev",
    "dev:web": "pnpm --filter @follstack/web dev",
    "dev:api": "pnpm --filter @follstack/api dev",
    "build": "pnpm --filter @follstack/api build",
    "build:api": "pnpm --filter @follstack/api build",
    "build:web": "pnpm --filter @follstack/shared --filter @follstack/ui --filter @follstack/web run build",
    "build:all": "pnpm --filter @follstack/shared --filter @follstack/ui --filter @follstack/api --filter @follstack/web run build",
    "start": "pnpm --filter @follstack/api start",
    "start:web": "pnpm --filter @follstack/web start",
    "start:all": "pnpm --parallel --filter @follstack/api --filter @follstack/web start",
    "lint": "pnpm --filter @follstack/web lint",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm --filter @follstack/api test",
    "test:e2e": "pnpm --filter @follstack/web test:e2e",
    "qa:smoke": "node scripts/qa-smoke.mjs",
    "qa:agent": "tsx scripts/qa-agent.ts"
  },
  "engines": {
    "node": "22.x",
    "pnpm": ">=10"
  },
  "volta": {
    "node": "22.14.0"
  },
  "devDependencies": {
    "@cursor/sdk": "^1.0.1",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3"
  }
}
