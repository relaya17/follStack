{
  "name": "follstack",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "turbo run dev --filter=@follstack/api --filter=@follstack/web",
    "dev:web": "turbo run dev --filter=@follstack/web",
    "dev:api": "turbo run dev --filter=@follstack/api",
    "build": "turbo run build --filter=@follstack/api",
    "build:api": "turbo run build --filter=@follstack/api",
    "build:web": "turbo run build --filter=@follstack/web...",
    "build:all": "turbo run build",
    "start": "pnpm --filter @follstack/api start",
    "start:web": "pnpm --filter @follstack/web start",
    "start:all": "pnpm --parallel --filter @follstack/api --filter @follstack/web start",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test --filter=@follstack/api",
    "test:e2e": "pnpm --filter @follstack/web test:e2e",
    "qa:smoke": "node scripts/qa-smoke.mjs",
    "qa:agent": "tsx scripts/qa-agent.ts"
  },
  "engines": {
    "node": "22.x",
    "pnpm": ">=10"
  },
  "volta": {
    "node": "22.14.0"
  },
  "devDependencies": {
    "@cursor/sdk": "^1.0.1",
    "tsx": "^4.20.3",
    "turbo": "^2.10.5",
    "typescript": "^5.9.3"
  }
}
