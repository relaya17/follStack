{
  "name": "follstack",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm --parallel --filter @follstack/api --filter @follstack/web dev",
    "dev:web": "pnpm --filter @follstack/web dev",
    "dev:api": "pnpm --filter @follstack/api dev",
    "build": "pnpm --filter @follstack/shared --filter @follstack/ui --filter @follstack/api --filter @follstack/web run build",
    "start": "pnpm --parallel --filter @follstack/api --filter @follstack/web start",
    "lint": "pnpm --filter @follstack/web lint",
    "typecheck": "pnpm -r run typecheck"
  },
  "engines": {
    "node": ">=20.9.0",
    "pnpm": ">=10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "unrs-resolver",
      "@scarf/scarf"
    ]
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
